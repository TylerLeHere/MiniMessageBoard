<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
</head>
<body>
  <h1><%= title %></h1>
  <a href="/new">+ New Message</a>

  <ul>
    <% messages.forEach((message, index) => { %>
      <li>
        <strong><%= message.user %></strong> said: "<%= message.text %>"
        <br>
        <small><%= message.added.toDateString() %></small>
        <br>
        <a href="/message/<%= index %>">Open</a>
      </li>
    <% }) %>
  </ul>
</body>
</html>